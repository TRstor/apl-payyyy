# ==============================
# SMTP Email Settings
# ==============================

# Privateemail / Namecheap:
SMTP_HOST=mail.privateemail.com
SMTP_PORT=465
SMTP_USER=your-email@domain.com
SMTP_PASS=your-password
SMTP_FROM=your-email@domain.com
SMTP_FROM_NAME=اسم المرسل

# Base URL (your domain or server URL)
BASE_URL=http://localhost:3000

# Server port
PORT=3000

# ==============================
# EdfaPay Payment Gateway
# ==============================
EDFA_MERCHANT_ID=your-merchant-id
EDFA_MERCHANT_PASSWORD=your-merchant-password
EDFA_CURRENCY=SAR
EDFA_COUNTRY=SA
EDFA_CITY=Riyadh
EDFA_ZIP=12221
