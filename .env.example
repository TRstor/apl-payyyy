# ==============================
# SMTP Email Settings
# ==============================

# Gmail Example:
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# Base URL (your domain or server URL)
BASE_URL=http://localhost:3000

# Server port
PORT=3000
